successfulApps = new ArrayList();
    failedApps = new ArrayList();
  	failedAppsErrors = new ArrayList();
    applications = context.getObjects(Application.class);

    try {
      for (Application app : applications) {
        if (!"sailpoint.connector.DelimitedFileConnector".equals(app.getConnector()) @and app.getConnector() != null) {
          Connector connector = ConnectorFactory.getConnector(app, null);
          try {
            connector.testConfiguration();
            successfulApps.add(app.getName());
          } catch (Exception e) {
            //errorMessage = e.toString();
           // errorDetails = errorMessage.substring(errorMessage.indexOf("[ Error details ]"));
            
            failedApps.add(app.getName());
            failedAppsErrors.add(e.toString());
          }
      	}
      }
    } catch (Exception e) {
      return "failed";
    }
	
