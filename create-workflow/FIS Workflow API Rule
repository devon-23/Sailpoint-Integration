<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE Rule PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Rule name="Test Create Entitlement Group Workflow" type="IdentityActivationRule">
  <Description>
    Test rule for validating the Create Entitlement Group workflow.
    This rule simulates the API call that would invoke the workflow with various test scenarios.
    Use this to verify the workflow before sharing API token access with other teams.
  </Description>
  
  <Signature>
    <Inputs/>
    <Returns>
      <Argument name="testResults" type="java.util.List">
        List of test execution results
      </Argument>
    </Returns>
    <Modification time="1700000000000"/>
  </Signature>
  
  <Source>
import sailpoint.object.Workflow;
import sailpoint.object.WorkflowCase;
import sailpoint.object.Application;
import sailpoint.object.Entitlement;
import sailpoint.object.QueryOptions;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

/**
 * Test Rule: Create Entitlement Group Workflow Tester
 * 
 * Test Scenarios:
 * 1. Basic successful creation
 * 2. Duplicate group handling
 * 3. Invalid application handling
 * 4. Missing required parameters
 * 5. With group owner
 */

List testResults = new ArrayList();

// Helper method to log test results
void logTestResult(String testName, String status, String message) {
  Map result = new HashMap();
  result.put("testName", testName);
  result.put("status", status);
  result.put("message", message);
  result.put("timestamp", System.currentTimeMillis());
  testResults.add(result);
  
  String logMessage = "[" + status + "] " + testName + ": " + message;
  if (status.equals("PASS")) {
    log.info(logMessage);
  } else if (status.equals("FAIL")) {
    log.error(logMessage);
  } else {
    log.warn(logMessage);
  }
}

// Test 1: Validate that workflow exists
try {
  Workflow workflow = context.getObjectByName(Workflow.class, "Create Entitlement Group");
  
  if (workflow != null) {
    logTestResult("Workflow Existence", "PASS", "Workflow 'Create Entitlement Group' found");
  } else {
    logTestResult("Workflow Existence", "FAIL", "Workflow 'Create Entitlement Group' not found");
  }
} catch (Exception e) {
  logTestResult("Workflow Existence", "FAIL", "Exception: " + e.getMessage());
}

// Test 2: Get test application
Application testApp = null;
try {
  testApp = context.getObjectByName(Application.class, "Active Directory");
  
  if (testApp != null) {
    logTestResult("Test Application Retrieval", "PASS", 
      "Found test application: " + testApp.getName());
  } else {
    logTestResult("Test Application Retrieval", "WARN", 
      "Test application 'Active Directory' not found. Using first available application.");
    
    // Fallback: get first available application
    QueryOptions qo = new QueryOptions();
    qo.setLimit(1);
    testApp = context.getObjects(Application.class, qo).get(0);
    
    if (testApp != null) {
      logTestResult("Fallback Application", "PASS", 
        "Using application: " + testApp.getName());
    }
  }
} catch (Exception e) {
  logTestResult("Application Setup", "FAIL", "Could not find test application: " + e.getMessage());
}

// Test 3: Basic Workflow Invocation (Dry Run)
if (testApp != null) {
  try {
    String testGroupName = "TEST_GROUP_" + System.currentTimeMillis();
    String testDisplayName = "Test Entitlement Group";
    String testDescription = "This is a test entitlement group created by test rule";
    
    Map arguments = new HashMap();
    arguments.put("applicationName", testApp.getName());
    arguments.put("groupName", testGroupName);
    arguments.put("displayName", testDisplayName);
    arguments.put("groupDescription", testDescription);
    arguments.put("groupOwner", "spadmin");
    
    logTestResult("Workflow Parameter Setup", "PASS", 
      "Prepared test parameters for application: " + testApp.getName());
    
    // Test 4: Validate all required parameters are present
    boolean allParametersValid = true;
    String missingParams = "";
    
    if (arguments.get("applicationName") == null) {
      allParametersValid = false;
      missingParams += "applicationName, ";
    }
    if (arguments.get("groupName") == null) {
      allParametersValid = false;
      missingParams += "groupName, ";
    }
    if (arguments.get("groupDescription") == null) {
      allParametersValid = false;
      missingParams += "groupDescription, ";
    }
    
    if (allParametersValid) {
      logTestResult("Required Parameters Validation", "PASS", 
        "All required parameters present");
    } else {
      logTestResult("Required Parameters Validation", "FAIL", 
        "Missing parameters: " + missingParams);
    }
    
    // Test 5: Verify Entitlement doesn't already exist
    try {
      QueryOptions qo = new QueryOptions();
      qo.addFilter("name", testGroupName);
      qo.addFilter("applicationId", testApp.getId());
      
      Entitlement existingEnt = context.getObjectByQuery(Entitlement.class, qo);
      
      if (existingEnt == null) {
        logTestResult("Pre-Existence Check", "PASS", 
          "Test group does not already exist");
      } else {
        logTestResult("Pre-Existence Check", "WARN", 
          "Test group already exists: " + existingEnt.getId());
      }
    } catch (Exception e) {
      logTestResult("Pre-Existence Check", "WARN", 
        "Could not verify pre-existence: " + e.getMessage());
    }
    
    // Test 6: Test with missing required parameter
    try {
      Map badArguments = new HashMap();
      badArguments.put("applicationName", testApp.getName());
      // Missing groupName - should fail
      badArguments.put("groupDescription", testDescription);
      
      logTestResult("Missing Parameter Detection", "PASS", 
        "Identified scenario with missing groupName parameter");
    } catch (Exception e) {
      logTestResult("Missing Parameter Detection", "FAIL", 
        "Exception: " + e.getMessage());
    }
    
    // Test 7: Test with custom owner
    try {
      Map ownerTestArgs = new HashMap();
      ownerTestArgs.put("applicationName", testApp.getName());
      ownerTestArgs.put("groupName", "TEST_GROUP_WITH_OWNER_" + System.currentTimeMillis());
      ownerTestArgs.put("groupDescription", "Group with owner assignment");
      ownerTestArgs.put("displayName", "Test Group With Owner");
      ownerTestArgs.put("groupOwner", "spadmin");
      
      logTestResult("Custom Owner Parameter", "PASS", 
        "Test parameters prepared for owner assignment");
    } catch (Exception e) {
      logTestResult("Custom Owner Parameter", "FAIL", 
        "Exception: " + e.getMessage());
    }
    
  } catch (Exception e) {
    logTestResult("Workflow Invocation Test", "FAIL", 
      "Exception during test: " + e.getMessage());
  }
}

// Test 8: Configuration Summary
try {
  Map configSummary = new HashMap();
  configSummary.put("IIQ Version", System.getProperty("sailpoint.version"));
  configSummary.put("Test Execution Time", new Date());
  configSummary.put("Total Tests", testResults.size());
  
  long passCount = testResults.stream()
    .filter(r -> r.get("status").equals("PASS"))
    .count();
  long failCount = testResults.stream()
    .filter(r -> r.get("status").equals("FAIL"))
    .count();
  long warnCount = testResults.stream()
    .filter(r -> r.get("status").equals("WARN"))
    .count();
  
  logTestResult("Test Summary", "INFO", 
    "Passed: " + passCount + ", Failed: " + failCount + ", Warnings: " + warnCount);
    
} catch (Exception e) {
  logTestResult("Summary Generation", "WARN", 
    "Could not generate summary: " + e.getMessage());
}

// Print detailed results for console review
log.info("=== TEST EXECUTION RESULTS ===");
for (Object resultObj : testResults) {
  Map result = (Map) resultObj;
  log.info(result.toString());
}

return testResults;
  </Source>
</Rule>
