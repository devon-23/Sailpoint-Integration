<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Rule PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Rule name="Test Create AD Group" type="GenericObject">
  <Description>Simple test</Description>
  <Signature returnType="void"/>
  <Body>
    <![CDATA[
import sailpoint.object.*;
import sailpoint.tools.*;
import java.util.*;

log.info("TEST START");

try {
  Workflow wf = (Workflow) context.getObjectByName(Workflow.class, "Create AD Group from API");
  log.info("Workflow: " + (wf != null ? wf.getName() : "null"));
  
  if (wf == null) {
    log.error("Workflow not found");
    return;
  }
  
  HashMap params = new HashMap();
  params.put("applicationName", "Active Directory");
  params.put("groupName", "TEST-" + System.currentTimeMillis());
  params.put("groupDescription", "Test");
  params.put("groupOwner", "CN=Administrator,CN=Users,DC=company,DC=com");
  params.put("groupType", "Security");
  params.put("groupScope", "Global");
  params.put("organizationalUnit", "CN=Users,DC=company,DC=com");
  
  log.info("Launching workflow");
  
  WorkflowLaunch wfLaunch = new WorkflowLaunch();
  wfLaunch.setWorkflowName(wf.getName());
  wfLaunch.setWorkflowRef(wf.getName());
  wfLaunch.setCaseName("Test-" + System.currentTimeMillis());
  wfLaunch.setVariables(params);
  
  Workflower wfer = new Workflower(context);
  WorkflowLaunch launch = wfer.launch(wfLaunch);
  
  log.info("Launch result: " + (launch != null ? "success" : "null"));
  
  log.info("TEST COMPLETE");
  
} catch (Exception e) {
  log.error("EXCEPTION: " + e.getMessage());
}
    ]]>
  </Body>
</Rule>
