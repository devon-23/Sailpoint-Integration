<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Rule PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Rule name="Test Create AD Group Workflow" type="GenericObject">
  <Description>
    Simplest test for Create AD Group workflow in IIQ 8.4
    Just call the workflow and log results
  </Description>
  <Signature returnType="void"/>
  <Body>
    <![CDATA[
import sailpoint.object.*;
import sailpoint.tools.*;
import java.util.*;

log.info("===== SIMPLE WORKFLOW TEST =====");

try {
  // Build parameters
  Map params = new HashMap();
  params.put("applicationName", "Active Directory");
  params.put("groupName", "TEST-" + System.currentTimeMillis());
  params.put("groupDescription", "Test group");
  params.put("groupOwner", "CN=Administrator,CN=Users,DC=company,DC=com");
  params.put("groupType", "Security");
  params.put("groupScope", "Global");
  params.put("organizationalUnit", "CN=Users,DC=company,DC=com");
  
  log.info("Testing with group: " + params.get("groupName"));
  
  // Get workflow
  Workflow wf = context.getObjectByName(Workflow.class, "Create AD Group from API");
  
  if (wf == null) {
    log.error("Workflow not found!");
    return;
  }
  
  log.info("Workflow found, executing...");
  
  // Create context
  WorkflowContext wfCtx = new WorkflowContext(context, wf);
  wfCtx.setVariables(params);
  
  // Execute
  WorkflowEngine engine = new WorkflowEngine(context);
  WorkflowCase case1 = engine.executeWorkflow(wfCtx);
  
  context.saveObject(case1);
  context.commitTransaction();
  
  log.info("Workflow case: " + case1.getId());
  
  // Wait max 2 minutes
  int maxWait = 120;
  int waited = 0;
  
  while (!case1.isFinalized() &amp;&amp; waited < maxWait) {
    log.info("Waiting... " + waited + "s");
    Thread.sleep(1000);
    waited++;
    
    case1 = context.getObjectById(WorkflowCase.class, case1.getId());
    if (case1 == null) break;
  }
  
  // Show results
  log.info("\n===== RESULTS =====");
  log.info("State: " + case1.getState());
  
  if (case1.getVariables() != null) {
    Map vars = case1.getVariables();
    Object success = vars.get("isSuccess");
    Object reqId = vars.get("requestId");
    Object error = vars.get("errorMessage");
    
    log.info("Success: " + success);
    log.info("RequestID: " + reqId);
    log.info("Error: " + error);
    
    if ("true".equals(success.toString())) {
      log.info("\n✓ SUCCESS! Group created");
    } else {
      log.error("\n✗ FAILED! " + error);
    }
  }
  
  log.info("===== DONE =====");
  
} catch (Exception e) {
  log.error("Exception: " + e.getMessage());
  e.printStackTrace();
}
    ]]>
  </Body>
</Rule>
