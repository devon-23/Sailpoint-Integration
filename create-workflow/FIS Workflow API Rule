<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Rule PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Rule name="Test Create AD Group Workflow" type="GenericObject">
  <Description>
    Test rule for Create AD Group workflow - IIQ 8.4
    Uses WorkflowLaunch and Workflower pattern with correct methods
  </Description>
  <Signature returnType="void"/>
  <Body>
    <![CDATA[
import sailpoint.object.*;
import sailpoint.tools.*;
import java.util.*;

log.info("===== TEST: Create AD Group Workflow =====");

try {
  // Get the workflow
  Workflow wf = (Workflow) context.getObjectByName(Workflow.class, "Create AD Group from API");
  
  if (wf == null) {
    log.error("ERROR: Workflow 'Create AD Group from API' not found!");
    return;
  }
  
  log.info("Workflow found: " + wf.getName());
  
  // Create test parameters
  HashMap launchArgsMap = new HashMap();
  String testGroupName = "TEST-WF-" + System.currentTimeMillis();
  
  launchArgsMap.put("applicationName", "Active Directory");
  launchArgsMap.put("groupName", testGroupName);
  launchArgsMap.put("groupDescription", "Test group from rule");
  launchArgsMap.put("groupOwner", "CN=Administrator,CN=Users,DC=company,DC=com");
  launchArgsMap.put("groupType", "Security");
  launchArgsMap.put("groupScope", "Global");
  launchArgsMap.put("organizationalUnit", "CN=Users,DC=company,DC=com");
  launchArgsMap.put("groupEmail", "testgroup@company.com");
  
  log.info("Test Parameters:");
  log.info("  Group Name: " + testGroupName);
  log.info("  Owner: CN=Administrator,CN=Users,DC=company,DC=com");
  
  // Create WorkflowLaunch object
  WorkflowLaunch wflaunch = new WorkflowLaunch();
  wflaunch.setWorkflowName(wf.getName());
  wflaunch.setWorkflowRef(wf.getName());
  wflaunch.setCaseName("Test: " + testGroupName);
  wflaunch.setVariables(launchArgsMap);
  
  // Launch the workflow using Workflower
  log.info("\nLaunching workflow...");
  Workflower workflower = new Workflower(context);
  WorkflowLaunch launch = workflower.launch(wflaunch);
  
  if (launch == null) {
    log.error("ERROR: Failed to launch workflow!");
    return;
  }
  
  log.info("Workflow launched!");
  
  // Get case ID - try multiple methods
  String caseId = null;
  
  // Method 1: Try getId()
  try {
    caseId = launch.getId();
    if (caseId != null &amp;&amp; !caseId.isEmpty()) {
      log.info("Case ID (from getId): " + caseId);
    }
  } catch (Exception e) {
    log.debug("getId() not available: " + e.getMessage());
  }
  
  // Method 2: Try getWorkflowCase()
  WorkflowCase wfCase = null;
  try {
    wfCase = launch.getWorkflowCase();
    if (wfCase != null) {
      caseId = wfCase.getId();
      log.info("Case ID (from getWorkflowCase): " + caseId);
    }
  } catch (Exception e) {
    log.debug("getWorkflowCase() not available: " + e.getMessage());
  }
  
  // Method 3: Search for workflow cases with our case name
  if (caseId == null) {
    log.info("Searching for workflow case...");
    String caseName = "Test: " + testGroupName;
    
    Iterator cases = context.search(WorkflowCase.class, new QueryOptions());
    while (cases.hasNext()) {
      WorkflowCase candidate = (WorkflowCase) cases.next();
      if (candidate.getCaseName() != null &amp;&amp; candidate.getCaseName().equals(caseName)) {
        wfCase = candidate;
        caseId = candidate.getId();
        log.info("Case ID (from search): " + caseId);
        break;
      }
    }
  }
  
  // If we found a case, wait for it to complete
  if (wfCase != null || caseId != null) {
    log.info("Waiting for workflow completion...");
    
    int maxWait = 120; // seconds
    for (int i = 0; i < maxWait; i++) {
      if (wfCase == null &amp;&amp; caseId != null) {
        wfCase = (WorkflowCase) context.getObjectById(WorkflowCase.class, caseId);
      }
      
      if (wfCase != null &amp;&amp; wfCase.isFinalized()) {
        log.info("Workflow completed!");
        break;
      }
      
      if (wfCase != null) {
        log.info("  Status: " + wfCase.getState() + " (" + (i + 1) + "s)");
      }
      
      Thread.sleep(1000);
    }
    
    // Display results
    if (wfCase != null) {
      log.info("\n===== RESULTS =====");
      log.info("Case ID: " + wfCase.getId());
      log.info("State: " + wfCase.getState());
      
      Map variables = wfCase.getVariables();
      if (variables != null) {
        Object isSuccess = variables.get("isSuccess");
        Object errorMessage = variables.get("errorMessage");
        Object requestId = variables.get("requestId");
        
        log.info("\nOutput:");
        log.info("  isSuccess: " + (isSuccess != null ? isSuccess : "null"));
        log.info("  errorMessage: " + (errorMessage != null ? errorMessage : "null"));
        log.info("  requestId: " + (requestId != null ? requestId : "null"));
        
        if (isSuccess != null &amp;&amp; "true".equals(isSuccess.toString())) {
          log.info("\n✓ SUCCESS - Group created!");
          log.info("  Group: " + testGroupName);
          log.info("  RequestID: " + requestId);
        } else {
          log.error("\n✗ FAILED - " + errorMessage);
        }
      }
    }
  } else {
    log.warn("WARNING: Could not find workflow case");
  }
  
  log.info("\n===== TEST COMPLETE =====");
  
} catch (Exception ex) {
  log.error("EXCEPTION: " + ex.getMessage());
  ex.printStackTrace();
}
    ]]>
  </Body>
</Rule>
