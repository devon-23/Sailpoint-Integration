<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Rule PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Rule name="Test Create AD Group Workflow" type="GenericObject">
  <Description>
    Test rule for Create AD Group workflow - IIQ 8.4 compatible
    Uses WorkflowRequest to launch workflow
  </Description>
  <Signature returnType="void"/>
  <Body>
    <![CDATA[
import sailpoint.object.*;
import sailpoint.tools.*;
import java.util.*;

log.info("===== TEST: Create AD Group Workflow =====");

try {
  // Get the workflow
  Workflow workflow = context.getObjectByName(Workflow.class, "Create AD Group from API");
  
  if (workflow == null) {
    log.error("ERROR: Workflow not found!");
    return;
  }
  
  log.info("✓ Workflow found: " + workflow.getName());
  
  // Create workflow parameters
  Map params = new HashMap();
  String testGroupName = "TEST-WF-" + System.currentTimeMillis();
  
  params.put("applicationName", "Active Directory");
  params.put("groupName", testGroupName);
  params.put("groupDescription", "Test group created from rule");
  params.put("groupOwner", "CN=Administrator,CN=Users,DC=company,DC=com");
  params.put("groupType", "Security");
  params.put("groupScope", "Global");
  params.put("organizationalUnit", "CN=Users,DC=company,DC=com");
  params.put("groupEmail", "testgroup@company.com");
  
  Map additionalAttrs = new HashMap();
  additionalAttrs.put("info", "Created from test rule");
  additionalAttrs.put("notes", "Workflow test execution");
  params.put("additionalAttributes", additionalAttrs);
  
  log.info("Test Parameters:");
  log.info("  Group Name: " + testGroupName);
  log.info("  Group Description: Test group created from rule");
  log.info("  Group Owner: CN=Administrator,CN=Users,DC=company,DC=com");
  log.info("  Group Type: Security");
  log.info("  Group Scope: Global");
  log.info("  OU: CN=Users,DC=company,DC=com");
  
  // Create a WorkflowRequest
  log.info("\nLaunching workflow...");
  WorkflowRequest request = new WorkflowRequest();
  request.setWorkflow(workflow);
  request.setVariables(params);
  
  // Get the request executor
  Launcher launcher = new Launcher(context);
  
  // Execute the request
  WorkflowCase workflowCase = launcher.executeWorkflow(request);
  
  if (workflowCase == null) {
    log.error("ERROR: Failed to launch workflow!");
    return;
  }
  
  String caseId = workflowCase.getId();
  log.info("✓ Workflow launched - Case ID: " + caseId);
  
  // Wait for workflow to complete
  log.info("\nWaiting for workflow to complete...");
  int maxSeconds = 120;
  int secondsWaited = 0;
  
  while (secondsWaited < maxSeconds) {
    // Reload the case
    workflowCase = context.getObjectById(WorkflowCase.class, caseId);
    
    if (workflowCase == null) {
      log.error("ERROR: Workflow case not found!");
      break;
    }
    
    // Check if finalized
    if (workflowCase.isFinalized()) {
      log.info("✓ Workflow completed");
      break;
    }
    
    // Log status
    log.info("  Status: " + workflowCase.getState() + " (" + secondsWaited + "s)");
    
    // Sleep and wait
    Thread.sleep(1000);
    secondsWaited++;
  }
  
  if (secondsWaited >= maxSeconds) {
    log.warn("WARNING: Workflow did not complete within " + maxSeconds + " seconds");
  }
  
  // Get the final result
  log.info("\n===== WORKFLOW RESULTS =====");
  log.info("Case ID: " + caseId);
  log.info("State: " + workflowCase.getState());
  
  // Extract output variables
  Map variables = workflowCase.getVariables();
  
  if (variables != null) {
    Object reqId = variables.get("requestId");
    Object success = variables.get("isSuccess");
    Object error = variables.get("errorMessage");
    Object audit = variables.get("auditLog");
    
    log.info("\nOutput Variables:");
    log.info("  requestId: " + (reqId != null ? reqId : "null"));
    log.info("  isSuccess: " + (success != null ? success : "null"));
    log.info("  errorMessage: " + (error != null ? error : "null"));
    
    // Print results based on success/failure
    if (success != null) {
      String successStr = success.toString();
      
      if ("true".equals(successStr)) {
        log.info("\n========== ✓ SUCCESS ==========");
        log.info("Workflow executed successfully!");
        log.info("Group Name: " + testGroupName);
        log.info("Request ID: " + reqId);
        if (audit != null) {
          log.info("Details: " + audit);
        }
        log.info("============================");
      } else if ("false".equals(successStr)) {
        log.error("\n========== ✗ FAILED ==========");
        log.error("Workflow execution failed!");
        log.error("Error: " + error);
        log.error("Request ID: " + reqId);
        log.error("============================");
      } else {
        log.warn("\n========== ? UNKNOWN ==========");
        log.warn("Unknown status: " + successStr);
        log.warn("============================");
      }
    }
  } else {
    log.warn("No output variables returned");
  }
  
  log.info("\n===== TEST COMPLETE =====");
  
} catch (Exception ex) {
  log.error("EXCEPTION: " + ex.getClass().getName() + ": " + ex.getMessage());
  
  // Print stack trace for debugging
  StringWriter sw = new StringWriter();
  PrintWriter pw = new PrintWriter(sw);
  ex.printStackTrace(pw);
  log.error("Stack trace:\n" + sw.toString());
}
    ]]>
  </Body>
</Rule>
